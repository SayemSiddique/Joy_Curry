---
import type { MenuItem } from '@lib/api';
import { formatPrice } from '@lib/formatters';

interface Props {
  item: MenuItem;
  galleryMode?: boolean;
  // On the "Most Loved" strip, non-customizable items get a prominent one-tap
  // "Quick Add" (same add-btn data-* contract → existing delegated handler).
  // Bundles always keep their Configure → BundleModal flow.
  quickAdd?: boolean;
}

const { item, galleryMode = false, quickAdd = false } = Astro.props;

const {
  id,
  name,
  description,
  basePriceCents,
  imageUrl,
  inStock,
  isVegan,
  isVegetarian,
  isGlutenFree,
  isHalal,
  spiceLevel,
  category,
} = item;

// Emoji placeholder when no image
const CATEGORY_EMOJI: Record<string, string> = {
  'appetizer': '🥗',
  'salad': '🥗',
  'soup': '🍲',
  'vegetable-entree': '🥦',
  'vegan-entree': '🌱',
  'chicken-entree': '🍗',
  'meat-entree': '🥩',
  'fish-shrimp': '🦐',
  'tandoori': '🔥',
  'rice-biryani': '🍚',
  'express-lunch': '⚡',
  'bread': '🫓',
  'side': '🍛',
  'condiment': '🧄',
  'dessert': '🍮',
  'beverage': '🥤',
  'dinner-special': '🍽️',
  'combo': '🥘',
};

const isBundle = category === 'dinner-special' || category === 'combo';

const emoji = CATEGORY_EMOJI[category] ?? '🍽️';

// Serve next-gen formats where the asset exists: the browser picks the first
// <source> it can decode (AVIF → WebP) and falls back to the original raster.
// Derived by extension swap; if the .avif/.webp aren't present the <source>
// 404s silently and the <img> src wins, so this is safe before assets land.
const avifUrl = imageUrl ? imageUrl.replace(/\.(jpe?g|png)$/i, '.avif') : null;
const webpUrl = imageUrl ? imageUrl.replace(/\.(jpe?g|png)$/i, '.webp') : null;
---

<article
  class:list={['menu-card', { 'menu-card--out-of-stock': !inStock }]}
  data-category={category}
  data-name={name}
  data-keywords={(item.searchKeywords ?? []).join(' ')}
  data-is-vegan={String(isVegan)}
  data-is-vegetarian={String(isVegetarian)}
  data-is-gluten-free={String(isGlutenFree)}
  data-spice-level={spiceLevel ?? ''}
  data-price-cents={basePriceCents}
>
  <div class="menu-card__img-wrap">
    {imageUrl ? (
      <picture>
        {avifUrl && <source srcset={avifUrl} type="image/avif" />}
        {webpUrl && <source srcset={webpUrl} type="image/webp" />}
        <img
          class="menu-card__img"
          src={imageUrl}
          alt={name}
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
        />
      </picture>
    ) : (
      <div class="menu-card__img-placeholder">{emoji}</div>
    )}
    {!galleryMode && (
      <span class="menu-card__price-badge">{formatPrice(basePriceCents)}</span>
    )}
  </div>

  <div class="menu-card__body">
    <div class="menu-card__name-row">
      <h3 class="menu-card__name">{name}</h3>
    </div>

    {description && (
      <p class="menu-card__desc">{description}</p>
    )}

    <div class="menu-card__badges">
      {isVegan && <span class="badge badge--vegan">🌱 Vegan</span>}
      {!isVegan && isVegetarian && <span class="badge badge--veg">🟢 Veg</span>}
      {!isVegan && !isVegetarian && <span class="badge badge--nonveg">🔴 Non-Veg</span>}
      {isGlutenFree && <span class="badge badge--gf">GF</span>}
      {isHalal && <span class="badge badge--halal">Halal</span>}
      {spiceLevel && spiceLevel !== 'Mild' && (
        <span class="badge badge--spicy">
          {spiceLevel === 'Hot' ? '🌶🌶🌶' : '🌶🌶'} {spiceLevel}
        </span>
      )}
    </div>

    {!galleryMode && (
      isBundle ? (
        <button
          class="menu-card__configure-btn"
          disabled={!inStock}
          data-bundle-id={id}
          data-bundle-name={name}
          data-price-cents={basePriceCents}
          aria-label={inStock ? `Configure ${name}` : `${name} — sold out`}
        >
          {inStock ? '⚙ Configure' : 'Sold Out'}
        </button>
      ) : (
        <button
          class:list={['menu-card__add-btn', { 'menu-card__add-btn--quick': quickAdd }]}
          disabled={!inStock}
          data-item-id={id}
          data-item-name={name}
          data-price-cents={basePriceCents}
          aria-label={inStock
            ? quickAdd ? `Quick add ${name} to cart` : `Add ${name} to cart`
            : `${name} — sold out`}
        >
          {inStock ? (quickAdd ? '⚡ Quick Add' : '+ Add to Order') : 'Sold Out'}
        </button>
      )
    )}
  </div>
</article>
