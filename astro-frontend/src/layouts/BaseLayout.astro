---
import '@styles/global.css';
import CartDrawer from '@components/islands/CartDrawer';
import CheckoutModal from '@components/islands/CheckoutModal';
import AuthModal from '@components/islands/AuthModal';
import OrderHistory from '@components/islands/OrderHistory';
import RewardsPanel from '@components/islands/RewardsPanel';
import AdminPanel from '@components/islands/AdminPanel';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Joy Curry & Tandoor — Halal Indian Cuisine, Midtown Manhattan',
  description = 'Authentic Halal Indian cuisine since 1994. Order online from Joy Curry & Tandoor, 148 East 46th St, New York City.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Preload the brand display face (Playfair Display 700, latin subset) so
        headings paint with the real font on first paint instead of swapping in
        late (FOUT). Stale URL on a Google version bump degrades to a harmless
        unused-preload warning, never a broken page. */}
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="https://fonts.gstatic.com/s/playfairdisplay/v40/nuFvD-vYSZviVYUb_rj3ij__anPXJzDwcbmjWBN2PKeiunDXbtM.woff2"
      crossorigin
    />
    {/* Fonts loaded via a <link> in <head> (not a CSS @import) so they're
        discovered early in the preload scan, ahead of the font preload above. */}
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@400;500;700&family=DM+Mono:wght@400;500&display=swap"
    />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-nav" href="#main-content">Skip to main content</a>
    <slot />
    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>
    <CartDrawer client:idle />
    <CheckoutModal client:idle />
    <AuthModal client:idle />
    <OrderHistory client:idle />
    <RewardsPanel client:idle />
    <AdminPanel client:idle />
  </body>
</html>
