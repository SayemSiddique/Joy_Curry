# Backend server
NODE_ENV=development
PORT=3000

# CORS — set to the live frontend URL(s) in production (comma-separated)
CORS_ORIGIN=http://localhost:4321

# Database — PostgreSQL connection string (local or managed, e.g. Neon/Render)
DATABASE_URL=postgres://user:password@localhost:5432/joycurry

# Authentication (Phase 6) — generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here-never-commit
JWT_EXPIRES_IN=7d

# Email service (Phase 7) — Resend (https://resend.com)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=orders@joycurry.net

# AI service (Phase 8+) — Anthropic Claude API
# FUTURE — not yet active
ANTHROPIC_API_KEY=your-claude-api-key-here

# Stripe payment processing — activate when ready for live payments
# FUTURE — not yet active
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Clover POS integration — activate when owner approves live system
# FUTURE — not yet active
CLOVER_API_KEY=your-clover-api-key-here
CLOVER_MERCHANT_ID=your-clover-merchant-id

# Delivery partners — activate when ready for >4-mile external dispatch
# FUTURE — not yet active (choose one or both)
DOORDASH_DEVELOPER_ID=
DOORDASH_KEY_ID=
DOORDASH_SIGNING_SECRET=
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
