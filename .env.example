# Backend server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=./joy-curry.db

# API Base URL (frontend uses this in Phase 6)
API_BASE_URL=http://localhost:3000/api

# Authentication (added in Phase 6)
JWT_SECRET=your-secret-key-here-never-commit
JWT_EXPIRES_IN=7d

# Email service (added in Phase 7)
SENDGRID_API_KEY=your-sendgrid-key-here
SENDGRID_FROM_EMAIL=orders@joycurry.net

# AI service (added in Phase 8)
ANTHROPIC_API_KEY=your-claude-api-key-here
