# Copy to .env — Expo CLI loads it automatically.
# EXPO_PUBLIC_* values are inlined into the JS bundle at build time (public, never secrets).
# Live API: https://joy-curry-tandoor-api.onrender.com
# Local API: http://localhost:3000 (simulator) or http://<mac-lan-ip>:3000 (physical device)
EXPO_PUBLIC_API_BASE_URL=https://joy-curry-tandoor-api.onrender.com
# Origin that serves dish photos (imageUrl paths are web-root-relative).
EXPO_PUBLIC_WEB_ASSET_BASE_URL=https://joy-curry-web.vercel.app
# Stripe publishable key (test mode) — same pk_test_… used by web's PUBLIC_STRIPE_KEY.
# Public (safe to inline); the secret key lives only on the API. Card payments
# require a development build (@stripe/stripe-react-native is NOT in Expo Go).
EXPO_PUBLIC_STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
