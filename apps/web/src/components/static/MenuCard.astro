---
import type { MenuItem } from '@lib/core';
import { formatPrice } from '@lib/core';
import { categoryIcon, heartIcon, leafIcon, chefHatIcon, plusIcon } from '@lib/icons';

interface Props {
  item: MenuItem;
  galleryMode?: boolean;
  // On the "Most Loved" strip, non-customizable items get a prominent one-tap
  // "Quick Add" (same add-btn data-* contract → existing delegated handler).
  // Bundles always keep their Configure → BundleModal flow.
  quickAdd?: boolean;
  // Above-the-fold cards (first row of a section / hero strip) load eagerly with
  // high fetch priority so the LCP image isn't deferred by lazy-loading.
  aboveFold?: boolean;
}

const { item, galleryMode = false, quickAdd = false, aboveFold = false } = Astro.props;

const {
  id,
  name,
  description,
  basePriceCents,
  imageUrl,
  videoUrl,
  inStock,
  isVegan,
  isVegetarian,
  isGlutenFree,
  isHalal,
  spiceLevel,
  category,
} = item;

const isBundle = category === 'dinner-special' || category === 'combo';

const placeholderIcon = categoryIcon(category, 40);

// Serve next-gen formats + responsive sizes where the asset exists. The image
// pipeline (scripts/optimize-images.mjs) emits per slug: {base}-400.{avif,webp,jpg}
// (mobile card) and {base}-800.{ext} (tablet/desktop + modal), plus non-suffixed
// {base}.{ext} = 800w for back-compat. The browser picks the first <source> it
// can decode (AVIF → WebP), then the right width via srcset/sizes; if a variant
// is absent the <source> 404s silently and the <img> src wins — safe pre-assets.
const base = imageUrl ? imageUrl.replace(/\.(jpe?g|png)$/i, '') : null;
const srcsetFor = (ext: string) =>
  base ? `${base}-400.${ext} 400w, ${base}-800.${ext} 800w` : undefined;
// 45vw on phones (2-up grid), capped at 280px on larger viewports.
const sizes = '(max-width: 640px) 45vw, 280px';
---

<article
  class:list={['menu-card', { 'menu-card--out-of-stock': !inStock }]}
  data-category={category}
  data-name={name}
  data-keywords={(item.searchKeywords ?? []).join(' ')}
  data-is-vegan={String(isVegan)}
  data-is-vegetarian={String(isVegetarian)}
  data-is-gluten-free={String(isGlutenFree)}
  data-spice-level={spiceLevel ?? ''}
  data-price-cents={basePriceCents}
  data-item-json={JSON.stringify(item)}
>
  <div class="menu-card__img-wrap" data-open-dish="true" role="button" tabindex="0" aria-label={`View details for ${name}`}>
    <button
      class="menu-card__heart"
      type="button"
      data-favorite-item-id={id}
      aria-label={`Save ${name} to favorites`}
      aria-pressed="false"
    >♡</button>
    {videoUrl ? (
      <>
        <video
          class="menu-card__video"
          src={videoUrl}
          poster={imageUrl}
          muted
          loop
          playsinline
          preload="none"
          data-card-video="true"
          aria-label={name}
          width="400"
          height="267"
        />
        <div class="menu-card__img-placeholder" style="display:none" aria-hidden="true">
          <Fragment set:html={placeholderIcon} />
        </div>
      </>
    ) : imageUrl ? (
      <>
        <picture>
          <source srcset={srcsetFor('avif')} sizes={sizes} type="image/avif" />
          <source srcset={srcsetFor('webp')} sizes={sizes} type="image/webp" />
          <img
            class="menu-card__img"
            src={imageUrl}
            srcset={srcsetFor('jpg')}
            sizes={sizes}
            alt={name}
            loading={aboveFold ? 'eager' : 'lazy'}
            fetchpriority={aboveFold ? 'high' : 'auto'}
            decoding="async"
            width="400"
            height="300"
            onerror="this.closest('picture').style.display='none';this.closest('picture').nextElementSibling.style.display='flex';"
          />
        </picture>
        <div class="menu-card__img-placeholder" style="display:none" aria-hidden="true">
          <Fragment set:html={placeholderIcon} />
        </div>
      </>
    ) : (
      <div class="menu-card__img-placeholder" aria-hidden="true">
        <Fragment set:html={placeholderIcon} />
      </div>
    )}
    {!galleryMode && (
      <span class="menu-card__price-badge">{formatPrice(basePriceCents)}</span>
    )}
  </div>

  <div class="menu-card__body">
    <div class="menu-card__name-row">
      <h3 class="menu-card__name">{name}</h3>
    </div>

    {description && (
      <p class="menu-card__desc">{description}</p>
    )}

    <div class="menu-card__badges">
      {isVegan && <span class="badge badge--vegan"><Fragment set:html={leafIcon(12)} /> Vegan</span>}
      {!isVegan && isVegetarian && <span class="badge badge--veg"><span class="badge__dot badge__dot--veg" aria-hidden="true"></span> Veg</span>}
      {!isVegan && !isVegetarian && <span class="badge badge--nonveg"><span class="badge__dot badge__dot--nonveg" aria-hidden="true"></span> Non-Veg</span>}
      {isGlutenFree && <span class="badge badge--gf">GF</span>}
      {isHalal && <span class="badge badge--halal">Halal</span>}
      {(item.tags ?? []).includes('popular') && (
        <span class="badge badge--popular"><Fragment set:html={heartIcon(12)} /> Most Loved</span>
      )}
      {(item.tags ?? []).includes('chefs-pick') && (
        <span class="badge badge--chefs-pick"><Fragment set:html={chefHatIcon(12)} /> Chef's Pick</span>
      )}
      {spiceLevel && spiceLevel !== 'Mild' && (
        <span class="spice-meter" aria-label={`Spice level: ${spiceLevel}`}>
          {(() => {
            const lvl = spiceLevel === 'Hot' ? 3 : spiceLevel === 'Medium' ? 2 : 1;
            return (
              <>
                <span class="spice-meter__dots" aria-hidden="true">
                  {[1,2,3].map(i => (
                    <span class={`spice-dot${i <= lvl ? ' spice-dot--lit' : ''}`}></span>
                  ))}
                </span>
                <span class="spice-meter__label">{spiceLevel}</span>
              </>
            );
          })()}
        </span>
      )}
    </div>

    {!galleryMode && (
      isBundle ? (
        <button
          class="menu-card__configure-btn"
          disabled={!inStock}
          data-bundle-id={id}
          data-bundle-name={name}
          data-price-cents={basePriceCents}
          aria-label={inStock ? `Configure ${name}` : `${name} — sold out`}
        >
          {inStock ? <><Fragment set:html={plusIcon(13)} /> Configure</> : 'Sold Out'}
        </button>
      ) : (
        <button
          class:list={['menu-card__add-btn', { 'menu-card__add-btn--quick': quickAdd }]}
          disabled={!inStock}
          data-item-id={id}
          data-item-name={name}
          data-price-cents={basePriceCents}
          aria-label={inStock
            ? quickAdd ? `Quick add ${name} to cart` : `Add ${name} to cart`
            : `${name} — sold out`}
        >
          {inStock ? (quickAdd ? <><Fragment set:html={plusIcon(13)} /> Quick Add</> : <><Fragment set:html={plusIcon(13)} /> Add to Order</>) : 'Sold Out'}
        </button>
      )
    )}
  </div>
</article>

<style>
  .menu-card__video {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    transition: transform 500ms ease, opacity 300ms ease;
  }
  .menu-card__img-wrap:hover .menu-card__video,
  .menu-card__img-wrap:focus-visible .menu-card__video {
    transform: scale(1.08);
  }
</style>

<script>
  // Delegated video play/pause on hover
  if (!document.body.dataset.videoListenerAttached) {
    document.body.dataset.videoListenerAttached = 'true';
    document.body.addEventListener('mouseover', (e) => {
      const wrap = (e.target as Element).closest('.menu-card__img-wrap');
      const vid = wrap?.querySelector<HTMLVideoElement>('[data-card-video]');
      if (vid) vid.play().catch(() => {});
    });
    document.body.addEventListener('mouseleave', (e) => {
      const wrap = (e.target as Element).closest('.menu-card__img-wrap');
      const vid = wrap?.querySelector<HTMLVideoElement>('[data-card-video]');
      if (vid) { vid.pause(); vid.currentTime = 0; }
    }, true);
  }

  // Delegated handler for dish:open — Astro deduplicates this across card instances
  if (!document.body.dataset.dishListenerAttached) {
    document.body.dataset.dishListenerAttached = 'true';
    document.body.addEventListener('click', (e) => {
      const wrap = (e.target as Element).closest('[data-open-dish]');
      if (!wrap) return;
      const card = wrap.closest('[data-item-json]') as HTMLElement | null;
      if (!card?.dataset.itemJson) return;
      try {
        const item = JSON.parse(card.dataset.itemJson);
        window.dispatchEvent(new CustomEvent('dish:open', { detail: item }));
      } catch {}
    });
    document.body.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      const wrap = (e.target as Element).closest('[data-open-dish]') as HTMLElement | null;
      if (!wrap) return;
      const card = wrap.closest('[data-item-json]') as HTMLElement | null;
      if (!card?.dataset.itemJson) return;
      try {
        const item = JSON.parse(card.dataset.itemJson);
        window.dispatchEvent(new CustomEvent('dish:open', { detail: item }));
      } catch {}
    });
  }
</script>
