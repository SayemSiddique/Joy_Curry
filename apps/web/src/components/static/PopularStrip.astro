---
import type { MenuItem } from '@lib/core';
import MenuCard from './MenuCard.astro';

interface Props {
  items: MenuItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <section class="popular-strip" aria-labelledby="popular-strip-title">
    <div class="container">
      <div class="popular-strip__header">
        <h2 class="popular-strip__title" id="popular-strip-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align:-2px;color:var(--color-warning)"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg> Most Loved
        </h2>
        <span class="popular-strip__sub">Customer favorites</span>
      </div>
      <div class="popular-strip__track">
        {items.map((item) => (
          <div class="popular-strip__item">
            <MenuCard item={item} quickAdd />
          </div>
        ))}
      </div>
    </div>
  </section>
)}
