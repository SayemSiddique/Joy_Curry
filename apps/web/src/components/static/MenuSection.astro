---
import type { MenuItem } from '@lib/core';
import MenuCard from './MenuCard.astro';
import { categoryIcon } from '@lib/icons';

interface Props {
  category: string;
  label: string;
  emoji?: string;
  items: MenuItem[];
  galleryMode?: boolean;
  // Set on the first rendered section only: its first row of cards is the LCP,
  // so those images load eagerly instead of lazily.
  priority?: boolean;
}

const { category, label, items, galleryMode = false, priority = false } = Astro.props;

// First 3 cards form the visible first row above the fold on the priority section.
const ABOVE_FOLD_COUNT = 3;
---

<section
  class="menu-section"
  id={`cat-${category}`}
  data-category={category}
  aria-labelledby={`section-title-${category}`}
>
  <div class="menu-section__header">
    <h2 class="menu-section__title" id={`section-title-${category}`}>
      <span class="menu-section__icon" aria-hidden="true"><Fragment set:html={categoryIcon(category, 22)} /></span>{label}
    </h2>
    <span class="menu-section__count">{items.length} item{items.length !== 1 ? 's' : ''}</span>
  </div>

  <div class="menu-grid" data-section={category}>
    {items.map((item, i) => (
      <MenuCard item={item} galleryMode={galleryMode} aboveFold={priority && i < ABOVE_FOLD_COUNT} />
    ))}
  </div>
</section>
