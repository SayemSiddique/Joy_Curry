---
// Cart count and auth state are managed by React islands (Chunk E & G).
// This static component renders the shell; islands update #cart-count and swap auth buttons.
const path = Astro.url.pathname;
---

<nav class="navbar" aria-label="Main navigation">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo" aria-label="Joy Curry &amp; Tandoor — Home">
      <img src="/images/logo/navbar_logo.png" alt="Joy Curry & Tandoor" class="navbar__logo-img" />
    </a>

    <nav class="navbar__nav" aria-label="Site sections">
      <a
        href="/menu"
        class:list={['navbar__nav-link', { 'navbar__nav-link--active': path === '/menu' }]}
        aria-current={path === '/menu' ? 'page' : undefined}
      >MENU</a>
      <a
        href="/#story"
        class="navbar__nav-link"
      >OUR STORY</a>
      <a
        href="/#rewards"
        class="navbar__nav-link"
      >REWARDS</a>
      <button
        class="navbar__btn navbar__nav-link"
        id="navbar-orders-btn"
        aria-label="My orders"
        style="display: none"
      >MY ORDERS</button>
      <button
        class="navbar__btn navbar__nav-link"
        id="navbar-vault-btn"
        aria-label="Artisan Vault rewards"
        style="display: none"
      >✦ VAULT</button>
      <button
        class="navbar__btn navbar__nav-link"
        id="navbar-admin-btn"
        aria-label="Admin panel"
        style="display: none"
      >⚙ ADMIN</button>
    </nav>

    <div class="navbar__actions">
      <button
        class="navbar__btn navbar__btn--ghost"
        id="navbar-auth-btn"
        aria-label="Sign in to your account"
      >
        Sign In
      </button>

      <button
        class="navbar__btn navbar__btn--cart"
        id="navbar-cart-btn"
        aria-label="View cart"
      >
        🛒 Cart
        <span
          class="navbar__cart-count"
          id="cart-count"
          aria-label="items in cart"
          style="display: none"
        >0</span>
      </button>

      <a
        href="/order"
        class:list={['navbar__cta-block', { 'navbar__cta-block--active': path === '/order' }]}
        aria-current={path === '/order' ? 'page' : undefined}
      >ORDER ONLINE</a>
    </div>
  </div>
</nav>
