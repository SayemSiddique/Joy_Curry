---
// Cart count and auth state are managed by React islands (Chunk E & G).
// This static component renders the shell; islands update #cart-count and swap auth buttons.
const path = Astro.url.pathname;
---

<nav class="navbar" aria-label="Main navigation">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo" aria-label="Joy Curry &amp; Tandoor — Home">
      <img src="/images/logo/main_logo.png" alt="Joy Curry & Tandoor" class="navbar__logo-img" />
    </a>

    <nav class="navbar__nav" aria-label="Site sections">
      <a
        href="/menu"
        class:list={['navbar__nav-link', { 'navbar__nav-link--active': path === '/menu' }]}
        aria-current={path === '/menu' ? 'page' : undefined}
      >MENU</a>
      <a
        href="/#story"
        class="navbar__nav-link"
      >OUR STORY</a>
      <a
        href="/#rewards"
        class="navbar__nav-link"
      >REWARDS</a>
      <button
        class="navbar__btn navbar__nav-link"
        id="navbar-orders-btn"
        aria-label="My orders"
        style="display: none"
      >MY ORDERS</button>
      <button
        class="navbar__btn navbar__nav-link"
        id="navbar-vault-btn"
        aria-label="Artisan Vault rewards"
        style="display: none"
      >✦ VAULT</button>
      <button
        class="navbar__btn navbar__nav-link"
        id="navbar-admin-btn"
        aria-label="Admin panel"
        style="display: none"
      ><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align:-1px"><path d="M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915"/><circle cx="12" cy="12" r="3"/></svg> ADMIN</button>
    </nav>

    <div class="navbar__actions">
      <button
        class="navbar__btn navbar__btn--ghost"
        id="navbar-auth-btn"
        aria-label="Sign in to your account"
      >
        Sign In
      </button>

      <button
        class="navbar__btn navbar__btn--cart"
        id="navbar-cart-btn"
        aria-label="View cart"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align:-3px"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg> Cart
        <span
          class="navbar__cart-count"
          id="cart-count"
          aria-label="items in cart"
          style="display: none"
        >0</span>
      </button>

      <a
        href="/order"
        class:list={['navbar__cta-block', { 'navbar__cta-block--active': path === '/order' }]}
        aria-current={path === '/order' ? 'page' : undefined}
      >ORDER ONLINE</a>
    </div>
  </div>
</nav>
