---
import BaseLayout from '@layouts/BaseLayout.astro';
import Footer from '@components/static/Footer.astro';
import MenuSection from '@components/static/MenuSection.astro';
import PopularStrip from '@components/static/PopularStrip.astro';
import CategoryRail from '@components/islands/CategoryRail';
import SearchFilterBar from '@components/islands/SearchFilterBar';
import BundleModal from '@components/islands/BundleModal';
import OrderGate from '@components/islands/OrderGate';
import KitchenTicker from '@components/islands/KitchenTicker';
import MealConcierge from '@components/islands/MealConcierge';
import ReorderStrip from '@components/islands/ReorderStrip';
import SpecialsBanner from '@components/islands/SpecialsBanner';
import WelcomeStrip from '@components/islands/WelcomeStrip';
import GroupOrderBanner from '@components/islands/GroupOrderBanner';
import StockNotifier from '@components/islands/StockNotifier';
import type { MenuItem } from '@lib/core';
import { CATEGORIES, API_BASE_URL } from '@lib/core';

let menuItems: MenuItem[] = [];
let popularItems: MenuItem[] = [];
let fetchError: string | null = null;

try {
  // Full menu + "Most Loved" strip fetched in parallel, SSR (no client refetch).
  const [menuRes, popularRes] = await Promise.all([
    fetch(`${API_BASE_URL}/api/menu`),
    fetch(`${API_BASE_URL}/api/menu/popular`),
  ]);
  if (!menuRes.ok) throw new Error(`API ${menuRes.status}`);
  menuItems = (await menuRes.json()).data ?? [];
  // Popular strip is non-critical — degrade gracefully if it fails.
  if (popularRes.ok) popularItems = (await popularRes.json()).data ?? [];
} catch (err) {
  fetchError = (err as Error).message;
}

const byCategory = new Map<string, MenuItem[]>();
for (const cat of CATEGORIES) byCategory.set(cat.id, []);
for (const item of menuItems) {
  if (!byCategory.has(item.category)) byCategory.set(item.category, []);
  byCategory.get(item.category)!.push(item);
}

const activeCategories = CATEGORIES.filter((c) => (byCategory.get(c.id)?.length ?? 0) > 0);
---

<BaseLayout
  title="Order Online — Joy Curry & Tandoor | Halal Indian Cuisine, NYC"
  description="Order authentic halal Indian cuisine online for delivery or pickup. Browse our full menu, add to cart, and enjoy Chicken Tikka Masala, Goat Curry, Biryani and more."
>
  <SpecialsBanner client:idle />

  <!-- Order page header -->
  <div class="order-page__header">
    <div class="container">
      <h1 class="order-page__title">Order Online</h1>
      <p class="order-page__sub">100% Halal · Delivery & Pickup · Midtown Manhattan</p>
    </div>
  </div>

  <!-- P5-A: Personalised welcome strip for returning users -->
  <WelcomeStrip client:idle />
  <!-- P5-B: Group order participant banner (shown when ?group=uuid in URL) -->
  <GroupOrderBanner client:idle />
  <KitchenTicker client:idle />
  <SearchFilterBar client:idle menuItems={menuItems} />

  {!fetchError && <CategoryRail client:idle categories={activeCategories} />}

  <main id="main-content">
    <ReorderStrip client:idle />
  {!fetchError && <PopularStrip items={popularItems} />}
    {fetchError ? (
      <div class="container" style="padding: var(--space-20) 0; text-align: center;">
        <p style="color: var(--color-error); font-size: var(--text-lg);">
          Menu unavailable — {fetchError}
        </p>
        <p style="color: var(--color-text-muted); margin-top: var(--space-3);">
          Start the backend: <code>cd backend && node server.js</code>
        </p>
      </div>
    ) : (
      <div id="menu" class="container order-page-menu" style="padding-bottom: var(--space-20)">
        {activeCategories.map((cat, i) => {
          const items = byCategory.get(cat.id) ?? [];
          return (
            <MenuSection
              category={cat.id}
              label={cat.label}
              items={items}
              priority={i === 0}
            />
          );
        })}
      </div>
    )}
  </main>

  <!-- CartDrawer is mounted in BaseLayout (all pages) -->

  <!-- BundleModal island (Chunk I) -->
  <BundleModal client:idle menuItems={menuItems} />

  <!-- P2-D: AI Meal Concierge -->
  <MealConcierge client:idle menuItems={menuItems} />

  <!-- P6-A: Stock urgency notifier — polls /api/availability, injects badges on cards -->
  <StockNotifier client:idle />

  <!-- OrderGate island (Phase 3-C) — pickup/delivery fork -->
  <OrderGate client:idle />

  <Footer />
</BaseLayout>
