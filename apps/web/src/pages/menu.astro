---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/static/Navbar.astro';
import Footer from '@components/static/Footer.astro';
import MenuSection from '@components/static/MenuSection.astro';
import type { MenuItem } from '@lib/core';
import { CATEGORIES, API_BASE_URL } from '@lib/core';

let menuItems: MenuItem[] = [];
let fetchError: string | null = null;

try {
  const res = await fetch(`${API_BASE_URL}/api/menu`);
  if (!res.ok) throw new Error(`API ${res.status}`);
  const json = await res.json();
  menuItems = json.data ?? [];
} catch (err) {
  fetchError = (err as Error).message;
}

const byCategory = new Map<string, MenuItem[]>();
for (const cat of CATEGORIES) byCategory.set(cat.id, []);
for (const item of menuItems) {
  if (!byCategory.has(item.category)) byCategory.set(item.category, []);
  byCategory.get(item.category)!.push(item);
}

const activeCategories = CATEGORIES.filter((c) => (byCategory.get(c.id)?.length ?? 0) > 0);

// Structured data for Google rich results
const restaurantSchema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'Joy Curry & Tandoor',
  servesCuisine: 'Indian',
  hasMenu: {
    '@type': 'Menu',
    name: 'Joy Curry & Tandoor Menu',
    hasMenuSection: activeCategories.map((cat) => ({
      '@type': 'MenuSection',
      name: cat.label,
      hasMenuItem: (byCategory.get(cat.id) ?? []).map((item) => ({
        '@type': 'MenuItem',
        name: item.name,
        description: item.description,
        suitableForDiet: [
          item.isVegan ? 'https://schema.org/VeganDiet' : null,
          item.isVegetarian ? 'https://schema.org/VegetarianDiet' : null,
          item.isGlutenFree ? 'https://schema.org/GlutenFreeDiet' : null,
        ].filter(Boolean),
      })),
    })),
  },
};
---

<BaseLayout
  title="Our Menu — Joy Curry & Tandoor | Halal Indian Cuisine, NYC"
  description="Explore our full menu of authentic halal Indian cuisine — curries, tandoori, biryanis, and more. No prices, no pressure — just culinary storytelling."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(restaurantSchema)}
    slot="head"
  />

  <Navbar />

  <div class="menu-gallery__header">
    <div class="container">
      <h1 class="menu-gallery__title">Our Menu</h1>
      <p class="menu-gallery__intro">
        Freshly made, 100% Halal Indian cuisine crafted with heritage spices and traditional
        techniques. Explore our full selection — when you're ready to order, we'll be waiting.
      </p>
      <div class="menu-gallery__cta-row">
        <a href="/order" class="btn btn--cta btn--lg">Order Online →</a>
        <a href="/" class="btn btn--outline btn--lg" style="color: var(--color-hero-text); border-color: rgba(253,246,239,0.3);">← Back to Home</a>
      </div>
    </div>
  </div>

  <main id="main-content" class="menu-gallery">
    {fetchError ? (
      <div class="container" style="padding: var(--space-20) 0; text-align: center;">
        <p style="color: var(--color-error); font-size: var(--text-lg);">
          Menu unavailable — {fetchError}
        </p>
        <p style="color: var(--color-text-muted); margin-top: var(--space-3);">
          Start the backend: <code>cd backend && node server.js</code>
        </p>
      </div>
    ) : (
      <div class="container" style="padding-bottom: var(--space-20)">
        {activeCategories.map((cat, i) => {
          const items = byCategory.get(cat.id) ?? [];
          return (
            <MenuSection
              category={cat.id}
              label={cat.label}
              emoji={cat.emoji}
              items={items}
              galleryMode={true}
              priority={i === 0}
            />
          );
        })}
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
