---
import '@styles/global.css';
import CartDrawer from '@components/islands/CartDrawer';
import CheckoutModal from '@components/islands/CheckoutModal';
import AuthModal from '@components/islands/AuthModal';
import OrderHistory from '@components/islands/OrderHistory';
import RewardsPanel from '@components/islands/RewardsPanel';
import AdminPanel from '@components/islands/AdminPanel';
import DishDetailModal from '@components/islands/DishDetailModal';
import OrderTracker from '@components/islands/OrderTracker';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Joy Curry & Tandoor — Halal Indian Cuisine, Midtown Manhattan',
  description = 'Authentic Halal Indian cuisine since 1994. Order online from Joy Curry & Tandoor, 148 East 46th St, New York City.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/rubik/Rubik-Regular.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/rubik/Rubik-Bold.woff2"
      crossorigin
    />
    <slot name="head" />

    <script>
      // Client-side error tracking. No-ops unless PUBLIC_SENTRY_DSN is set at
      // build time, so it's safe on every page. Astro bundles this to an
      // external hashed module (CSP script-src 'self' compatible).
      import * as Sentry from '@sentry/browser';
      const dsn = import.meta.env.PUBLIC_SENTRY_DSN;
      if (dsn) {
        Sentry.init({
          dsn,
          environment: import.meta.env.MODE,
          tracesSampleRate: 0.1,
          sendDefaultPii: false,
        });
      }
    </script>

    <script>
      // Vercel Web Analytics (privacy-friendly pageviews). Prod-only; requires
      // "Web Analytics" to be enabled for the project in the Vercel dashboard.
      import { inject } from '@vercel/analytics';
      if (import.meta.env.PROD) inject();
    </script>
  </head>
  <body>
    <a class="skip-nav" href="#main-content">Skip to main content</a>
    <slot />
    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>
    <CartDrawer client:idle />
    <CheckoutModal client:idle />
    <AuthModal client:idle />
    <OrderHistory client:idle />
    <RewardsPanel client:idle />
    <AdminPanel client:idle />
    <DishDetailModal client:idle />
    <OrderTracker client:idle />
  </body>
</html>
